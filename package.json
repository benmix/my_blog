{
  "name": "ben-mix-s-blog",
  "version": "1.0.0",
  "private": true,
  "description": "ben-mix-s-blog",
  "license": "MIT",
  "author": "BenMix",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next --turbopack",
    "start": "next start",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "oxlint --config ./.oxlintrc.json .",
    "lint:fix": "oxlint --config ./.oxlintrc.json --fix --fix-suggestions .",
    "format": "oxfmt --config ./.oxfmtrc.json --check .",
    "format:write": "oxfmt --config ./.oxfmtrc.json .",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "obsidian-sync": "dotenvx run -- npx tsx scripts/obsidian-sync.ts",
    "photos:prepare": "tsx scripts/prepare-photos.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@content-collections/core": "^0.14.3",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@fumadocs/content-collections": "^1.2.7",
    "@paper-design/shaders-react": "0.0.72",
    "@radix-ui/react-slot": "^1.2.4",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fumadocs-core": "^16.7.5",
    "github-slugger": "^2.0.0",
    "katex": "^0.16.42",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.57.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "file-type": "^21.3.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-order": "^8.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  }
}
