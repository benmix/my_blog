{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "import", "typescript", "unicorn", "nextjs", "react-perf"],
  "rules": {
    "import/no-namespace": "error",
    "no-barrel-file": "error",
    "curly": ["error", "all"],
    "unicorn/no-useless-undefined": "error"
  }
}
